<launch>
  <!-- Arguments -->
  <arg name="cmd_vel_topic" default="/jackal_velocity_controller/cmd_vel" />
  <arg name="odom_topic" default="odom" />

  <!-- Move Base node -->
  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <!-- Load planner selection -->
    <rosparam file="$(find me5413_world)/params/move_base_params.yaml" command="load" />
    
    <!-- Load costmap configurations -->
    <rosparam file="$(find me5413_world)/params/costmap_common_params.yaml" command="load" ns="global_costmap" />
    <rosparam file="$(find me5413_world)/params/costmap_common_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find me5413_world)/params/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find me5413_world)/params/global_costmap_params.yaml" command="load" />
    
    <!-- Load TEB local planner params -->
    <rosparam file="$(find me5413_world)/params/teb_local_planner_params.yaml" command="load" />

    <!-- Re-map topics -->
    <remap from="cmd_vel" to="$(arg cmd_vel_topic)"/>
    <remap from="odom" to="$(arg odom_topic)"/>
  </node>
</launch>
