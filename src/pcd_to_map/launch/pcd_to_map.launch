<launch>
    <node pkg="pcd_to_map" name="pcd_to_map" type="pcd_to_map" output="screen">
    <!-- filepath to save .pcd file -->
    <param name="file_directory" value= "/home/marmot/zhouxin/ME5413_Final_Project/src/me5413_world/maps/liosam_pcd/" />
    <!-- .pcd file name-->
    <param name="file_name" value= "GlobalMap" />
    <!-- robot sensing window relative to local ground (User Request: -0.1 to 0.6) -->
    <param name="robot_reach_min" value= "0.0" />
    <param name="robot_reach_max" value= "1.0" />
    <!-- Global clipping bounds (ignored by the new window logic but kept for safety) -->
    <param name="thre_z_min" value= "0.0" />
    <param name="thre_z_max" value= "6.0" />
    <!-- Minimum thickness to be considered an obstacle (User Request: 0.3) -->
    <param name="min_obstacle_height" value= "0.2" />
    <!--0 select points in height range, １ select points out of height range -->
    <param name="flag_pass_through" value= "0" />
    <!-- radius filter's radius-->
    <param name="thre_radius" value= "0.3" />
    <!-- radius filter's points required-->
    <param name="thres_point_count" value= "10" />
    <!-- resolution of gripmap-->
    <param name="map_resolution" value= "0.05" />
    <!-- topic of gripmap, use map_server to save -->
    <param name="map_topic_name" value= "map" />
    </node>

</launch>
